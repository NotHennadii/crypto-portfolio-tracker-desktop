{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PnL Diary",
  "version": "0.1.3",
  "identifier": "com.sgi.pnl-diary",
  "build": {
    "beforeDevCommand": "npm run dev -- --port 1420",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build:desktop:web",
    "frontendDist": "../desktop-shell"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: blob: http://127.0.0.1:*; style-src 'self' 'unsafe-inline' http://127.0.0.1:*; script-src 'self' 'unsafe-inline' 'unsafe-eval' http://127.0.0.1:*; connect-src 'self' http://127.0.0.1:* https://api.github.com; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "desktop-runtime",
      "bin/node.exe"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
