NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
BINGX_SESSION_SECRET=

# Optional: allows app/API guest access without Supabase auth.
# Set both server + client flags when needed.
ALLOW_GUEST_MODE=false
NEXT_PUBLIC_ALLOW_GUEST_MODE=false

# Optional integrations
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_public_anon_key

# Required in production for encrypted API credential cookies.
BINGX_SESSION_SECRET=long_random_secret_value

# Optional custom API endpoints (default public exchange URLs):
